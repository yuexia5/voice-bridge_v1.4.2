HOST=0.0.0.0
PORT=8789

# voice-bridge 运行在 AstrBot 同一台服务器上时，一般保持 127.0.0.1 即可。
ASTRBOT_BRIDGE_URL=ws://127.0.0.1:8765
ASTRBOT_BRIDGE_TOKEN=请换成插件里的token

# 建议公网部署时开启。APP 设置页里填同一个 token。
APP_TOKEN=请换成APP连接token

# 手机 APP 访问音频文件时使用的公网地址。
# 直连测试可以填 http://服务器公网IP:8789
# Nginx + HTTPS 反代可以填 https://voice.example.com
PUBLIC_BASE_URL=

# 回复模式：
# astrbot：默认。后端只做 ASR 和 TTS，真正回复交给 AstrBot 当前会话，能使用 AstrBot 工具。
# backend_model：后端直接用下面的 Gemini/OpenAI 兼容多模态模型回复，适合“电话切到 Gemini”，但不保证 AstrBot 工具调用。
VOICE_REPLY_MODE=astrbot

# ASR：把 APP 上传的 WAV 语音转成文字，再交给 AstrBot。
# openai_chat_audio：走 /chat/completions + input_audio，适合支持音频输入的 OpenAI 兼容站。
# openai_transcriptions：走 /audio/transcriptions，适合支持标准转写接口的站。
ASR_PROVIDER=openai_chat_audio
ASR_API_KEY=请换成第三方站或 OpenAI 兼容站的key
ASR_BASE_URL=https://你的第三方站域名/v1
ASR_MODEL=gemini-2.5-flash
ASR_LANGUAGE=zh

# MiMo V2.5 TTS。MIMO_API_KEY 必填；其他字段不填则使用默认值。
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=Chloe
MIMO_TTS_FORMAT=wav
MIMO_TTS_STYLE=温柔、清晰、像正在电话里认真聊天，语速自然，情绪轻松。

# backend_model 模式使用。
# VOICE_REPLY_MODE=astrbot 时，这些不会用于逐轮回复，只用于通话结束后的 AI 总结增强；总结不会补充 Gemini/OpenAI 等模型身份。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://你的第三方站域名/v1
OPENAI_MODEL=gemini-2.5-flash

# 兼容旧变量名。OPENAI_* 和 GEMINI_* 二选一即可。
GEMINI_API_KEY=
GEMINI_API_FORMAT=openai
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OPENAI_RESPONSE_FORMAT=none

# 单段语音最长秒数，避免请求体过大。
VOICE_MAX_AUDIO_SECONDS=0
